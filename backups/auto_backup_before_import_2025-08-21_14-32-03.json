    "offer_accepted": {
        "base_key": "offer_accepted",
        "name": "Offer Accepted",
        "subject_key": "offer_accepted_sub",
        "subject": "Nueva orden en tu servicio — %service_title%",
        "body_key": "offer_accepted_body",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">Has recibido una nueva orden<\/h1>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">Hola %display_name%,<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Se ha generado una nueva orden en tu servicio <strong>%service_title%<\/strong> en <strong>%site_name%<\/strong>.<\/p>\n<a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%service_link%\">Ver servicio<\/a>",
        "switch_key": null,
        "enabled": true,
        "placeholders": [
