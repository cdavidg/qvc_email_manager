    "fl_email_payout_create": {
        "base_key": "fl_email_payout_create",
        "name": "Fl Email Payout Create",
        "subject_key": "fl_email_payout_create_sub",
        "subject": "Tu pago ha sido creado",
        "body_key": "fl_email_payout_create_body",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 18px;font-family: sans-serif\">Hola %display_name%,<\/h1>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">Hemos generado correctamente tu solicitud de retiro en <strong>QvaClick<\/strong>.<\/p>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\"><strong>Monto del retiro:<\/strong> %payout_amount%<\/p>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">En breve comenzará su procesamiento. Recibirás otra notificación una vez que el pago sea aprobado o enviado.<\/p>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">¿Tienes dudas? Solo responde a este correo, nuestro equipo estará encantado de ayudarte.<\/p>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">Gracias por confiar en <strong>QvaClick<\/strong> para impulsar tu trabajo freelance.<\/p>\n<h2 style=\"font-size: 22px;margin: 0 0 16px;font-family: sans-serif\"><a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%dashboard_link%\">Ver solicitud de retiro<\/a><\/h2>",
