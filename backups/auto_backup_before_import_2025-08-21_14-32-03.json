    "custom_offer": {
        "base_key": "custom_offer",
        "name": "Custom Offer",
        "subject_key": "custom_offer_subject",
        "subject": "Nueva oferta personalizada — %service_title%",
        "body_key": "custom_offer_body",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">Nueva oferta personalizada<\/h1>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">Hola %display_name%,<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Has recibido una oferta personalizada para tu servicio <strong>%service_title%<\/strong> en <strong>%site_name%<\/strong>.<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Entrega estimada:<\/strong> %service_delivery%<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Precio:<\/strong> %service_cost%<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Descripción:<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">%service_description%<\/p>\n<a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%service_link%\">Ver oferta<\/a>",
        "switch_key": "custom_offer_switch",
        "enabled": true,
        "placeholders": [
