        "subject_key": "offer_rejected_sub",
        "subject": "Tu oferta personalizada fue rechazada — %service_title%",
        "body_key": "offer_rejected_body",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">Oferta rechazada<\/h1>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">Hola %display_name%,<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Tu oferta personalizada para <strong>%service_title%<\/strong> ha sido rechazada.<\/p>\n<a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%service_link%\">Ver servicio<\/a>",
