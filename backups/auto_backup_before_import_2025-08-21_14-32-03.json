    "fl_user_email_account_activate": {
        "base_key": "fl_user_email_account_activate",
        "name": "Fl User Email Account Activate",
        "subject_key": "fl_user_email_account_activate_sub",
        "subject": "Tu cuenta ha sido activada en %site_name%",
        "body_key": "fl_user_email_account_activate_message",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">¡Hola %display_name%!<\/h1>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Tu cuenta en <strong>%site_name%<\/strong> ha sido activada por el equipo de administración.<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Ahora puedes acceder y comenzar a publicar o contratar servicios, gestionar tu perfil y explorar oportunidades.<\/p>\n<a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%login_url%\">Acceder a mi cuenta<\/a>",
        "switch_key": "fl_user_email_account_activate",
        "enabled": true,
        "placeholders": [
            "%display_name%",
            "%site_name%",
            "%login_url%"
        ],
        "last_modified": "",
        "source": "redux_direct"
    },
    "fl_user_email_account_deactivate": {
        "base_key": "fl_user_email_account_deactivate",
        "name": "Fl User Email Account Deactivate",
        "subject_key": "fl_user_email_account_deactivate_sub",
        "subject": "️ Cuenta de usuario desactivada en %site_name%",
        "body_key": "fl_user_email_account_deactivate_message",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">Cuenta de usuario desactivada<\/h1>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Se ha enviado esta notificación porque la cuenta de un usuario fue desactivada en <strong>%site_name%<\/strong>.<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Nombre de usuario:<\/strong> %display_name%<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Correo electrónico:<\/strong> %email%<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Motivo de desactivación:<\/strong> %deactivation_reason%<\/p>\n<a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%site_url%\">Abrir panel de administración<\/a>",
        "switch_key": "fl_user_email_account_deactivate",
        "enabled": true,
        "placeholders": [
            "%site_name%",
            "%display_name%",
            "%email%",
            "%deactivation_reason%",
            "%site_url%"
        ],
        "last_modified": "",
        "source": "redux_direct"
    },
    "fl_admin_email_account_activate": {
        "base_key": "fl_admin_email_account_activate",
        "name": "Fl Admin Email Account Activate",
        "subject_key": "fl_admin_email_account_activate_sub",
        "subject": "Se activó la cuenta de un usuario en %site_name%",
        "body_key": "fl_admin_email_account_activate_message",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">Cuenta activada<\/h1>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Se ha activado la cuenta de un usuario en <strong>%site_name%<\/strong>.<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Nombre de usuario:<\/strong> %display_name%<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Correo electrónico:<\/strong> %email%<\/p>\n<a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%site_url%\">Abrir panel de administración<\/a>",
        "switch_key": "fl_admin_email_account_activate",
        "enabled": true,
        "placeholders": [
            "%site_name%",
            "%display_name%",
            "%email%",
            "%site_url%"
        ],
        "last_modified": "",
        "source": "redux_direct"
    },
    "fl_user_email_verification": {
        "base_key": "fl_user_email_verification",
        "name": "Fl User Email Verification",
        "subject_key": "fl_user_email_verification_sub",
        "subject": "Confirma tu correo para activar tu cuenta en %site_name%",
        "body_key": "fl_user_email_verification_message",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">¡Hola, %display_name%!<\/h1>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Gracias por registrarte en <strong>%site_name%<\/strong>. Solo falta un paso para activar tu cuenta.<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Por favor, verifica tu dirección de correo electrónico haciendo clic en el botón:<\/p>\n<a style=\"background-color: #5aadff;color: #fff;padding: 12px 24px;border-radius: 4px;text-decoration: none;font-weight: bold\" href=\"%verification_link%\">Verificar mi cuenta<\/a>\n<p style=\"font-size: 16px;margin: 0 0 16px\">¿El botón no funciona? Copia y pega este enlace en tu navegador:<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">%verification_link%<\/p>",
        "switch_key": "fl_user_email_verification",
        "enabled": true,
        "placeholders": [
            "%display_name%",
            "%site_name%",
            "%verification_link%"
        ],
        "last_modified": "",
        "source": "redux_direct"
    },
    "fl_allow_user_email_verification": {
        "base_key": "fl_allow_user_email_verification",
        "name": "Fl Allow User Email Verification",
        "subject_key": "fl_allow_user_email_verification_sub",
        "subject": "Confirma tu correo para activar tu cuenta en %site_name%",
        "body_key": "fl_allow_user_email_verification_message",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">¡Hola, %display_name%!<\/h1>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Para completar la creación de tu cuenta, verifica tu correo electrónico haciendo clic en el botón:<\/p>\n<a style=\"background-color: #5aadff;color: #fff;padding: 12px 24px;border-radius: 4px;text-decoration: none;font-weight: bold\" href=\"%verification_link_allow%\">Verificar mi cuenta<\/a>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Si el botón no funciona, copia y pega este enlace en tu navegador:<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">%verification_link_allow%<\/p>",
        "switch_key": "fl_allow_user_email_verification",
        "enabled": true,
        "placeholders": [
            "%display_name%",
            "%verification_link_allow%"
        ],
        "last_modified": "",
        "source": "redux_direct"
    },
    "fl_user_reset": {
        "base_key": "fl_user_reset",
        "name": "Fl User Reset",
        "subject_key": "fl_user_reset_sub",
        "subject": "Restablecer tu contraseña en %site_name%",
        "body_key": "fl_user_reset_message",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">Hola %display_name%,<\/h1>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Recibimos tu solicitud para restablecer la contraseña de tu cuenta en <strong>%site_name%<\/strong>.<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Para continuar, haz clic en el botón:<\/p>\n<a style=\"background-color: #5aadff;color: #fff;padding: 12px 24px;border-radius: 4px;text-decoration: none;font-weight: bold\" href=\"%reset_link%\">Restablecer contraseña<\/a>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Si el botón no funciona, copia y pega este enlace en tu navegador:<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">%reset_link%<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Te recomendamos mantener tu contraseña segura y no compartirla con nadie.<\/p>",
        "switch_key": null,
        "enabled": true,
        "placeholders": [
            "%display_name%",
            "%site_name%",
            "%reset_link%"
        ],
        "last_modified": "",
        "source": "redux_direct"
    },
