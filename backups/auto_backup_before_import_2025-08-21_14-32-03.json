    "fl_email_sendto_Admin_account_activation": {
        "base_key": "fl_email_sendto_Admin_account_activation",
        "name": "Fl Email Sendto Admin Account Activation",
        "subject_key": "fl_email_sendto_Admin_account_activation_subj",
        "subject": "Nueva cuenta de usuario registrada",
        "body_key": "fl_email_sendto_Admin_account_activation_body",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 10px\">Nuevo usuario registrado<\/h1>\n<p style=\"font-size: 16px;margin: 0 0 16px\">Un nuevo usuario se ha registrado en tu sitio.<\/p>\n<p style=\"font-size: 16px;margin: 0 0 16px\"><strong>Enlace al perfil:<\/strong> <a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"%profile_link%\" target=\"_blank\" rel=\"noopener\">Ver perfil del usuario<\/a><\/p>",
        "switch_key": "fl_email_sendto_Admin_account_activation",
        "enabled": true,
        "placeholders": [
            "%profile_link%"
        ],
        "last_modified": "",
        "source": "redux_direct"
    },
