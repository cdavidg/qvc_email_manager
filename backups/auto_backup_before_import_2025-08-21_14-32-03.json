    "fl_email_hire_freelancer": {
        "base_key": "fl_email_hire_freelancer",
        "name": "Fl Email Hire Freelancer",
        "subject_key": "fl_email_hire_freelancer_sub",
        "subject": "¡Tienes una nueva invitación de proyecto en %site_name%!",
        "body_key": "fl_email_hire_freelancer_body",
        "body": "<h1 style=\"font-size: 28px;margin: 0 0 18px;font-family: sans-serif\">¡Hola, %display_name%!<\/h1>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">¡Buenas noticias! Un cliente acaba de invitarte a colaborar en <strong>%site_name%<\/strong>.<\/p>\n<p style=\"font-size: 18px;margin: 0 0 20px\"><a style=\"background: #3cbeb2;color: #fff !important;padding: 12px 22px;border-radius: 6px;font-weight: 600;text-decoration: none\" href=\"#\">Ver detalles de «%project_title%»<\/a><\/p>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\"><strong>Enlace directo:<\/strong> %project_link%<\/p>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">Revisa el proyecto y envía tu propuesta cuanto antes. Si tienes preguntas, responde a este correo; nuestro equipo está listo para ayudarte.<\/p>\n<p style=\"font-size: 16px;line-height: 1.5;margin: 0 0 16px;font-family: sans-serif\">¡Gracias por confiar en QvaClick para impulsar tu carrera freelance!<\/p>",
        "switch_key": "fl_email_hire_freelancer",
