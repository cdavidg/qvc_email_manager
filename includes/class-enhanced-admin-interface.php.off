    /**
     * Render badge count for navigation tabs
     */
    private function render_badge_count($tab) {
        global $wpdb;
        
        $count = 0;
        
        switch ($tab) {
            case 'general_inbox':
                $table = $wpdb->prefix . 'qvc_general_inbox';
                $count = $wpdb->get_var("SELECT COUNT(*) FROM {$table} WHERE status = 'unread'");
                break;
                
            case 'tickets':
                $table = $wpdb->prefix . 'qvc_support_tickets';
                $count = $wpdb->get_var("SELECT COUNT(*) FROM {$table} WHERE status = 'open'");
                break;
                
            case 'sales_leads':
                $table = $wpdb->prefix . 'qvc_sales_leads';
                $count = $wpdb->get_var("SELECT COUNT(*) FROM {$table} WHERE status = 'new'");
                break;
                
            case 'quarantine':
                $table = $wpdb->prefix . 'qvc_email_quarantine';
                $count = $wpdb->get_var("SELECT COUNT(*) FROM {$table} WHERE status = 'quarantined'");
                break;
        }
        
        if ($count > 0) {
            echo '<span class="qvc-tab-badge">' . esc_html($count) . '</span>';
        }
    }
    
    /**
     * Render General Inbox tab
     */
    private function render_general_inbox() {
        global $wpdb;
        
        // Get statistics
        $table = $wpdb->prefix . 'qvc_general_inbox';
        $stats = array(
            'total' => $wpdb->get_var("SELECT COUNT(*) FROM {$table}"),
            'unread' => $wpdb->get_var("SELECT COUNT(*) FROM {$table} WHERE status = 'unread'"),
            'requires_action' => $wpdb->get_var("SELECT COUNT(*) FROM {$table} WHERE requires_action = 1"),
            'processed_today' => $wpdb->get_var("SELECT COUNT(*) FROM {$table} WHERE processed_at >= CURDATE()")
        );
        
        // Get emails with filters
        $where = "1=1";
        $filter_status = isset($_GET['filter_status']) ? sanitize_text_field($_GET['filter_status']) : '';
        $filter_category = isset($_GET['filter_category']) ? sanitize_text_field($_GET['filter_category']) : '';
        $filter_priority = isset($_GET['filter_priority']) ? sanitize_text_field($_GET['filter_priority']) : '';
        
        if ($filter_status) {
            $where .= $wpdb->prepare(" AND status = %s", $filter_status);
        }
        if ($filter_category) {
            $where .= $wpdb->prepare(" AND category = %s", $filter_category);
        }
        if ($filter_priority) {
            $where .= $wpdb->prepare(" AND priority = %s", $filter_priority);
        }
        
        $emails = $wpdb->get_results("
            SELECT * FROM {$table} 
            WHERE {$where} 
            ORDER BY 
                CASE WHEN priority = 'high' THEN 1 
                     WHEN priority = 'medium' THEN 2 
                     ELSE 3 END,
                created_at DESC 
            LIMIT 50
        ");
        ?>
        
        <div class="qvc-general-inbox">
            <h2>Bandeja General de Emails</h2>
            <p>Emails clasificados automáticamente que no son tickets de soporte ni leads de ventas.</p>
            
            <!-- Statistics -->
            <div class="qvc-stats-grid">
                <div class="qvc-stat-card">
                    <h3><?php echo esc_html($stats['total']); ?></h3>
                    <p>Total de Emails</p>
                </div>
                <div class="qvc-stat-card">
                    <h3><?php echo esc_html($stats['unread']); ?></h3>
                    <p>Sin Leer</p>
                </div>
                <div class="qvc-stat-card">
                    <h3><?php echo esc_html($stats['requires_action']); ?></h3>
                    <p>Requieren Acción</p>
                </div>
                <div class="qvc-stat-card">
                    <h3><?php echo esc_html($stats['processed_today']); ?></h3>
                    <p>Procesados Hoy</p>
                </div>
            </div>
            
            <!-- Filters -->
            <div class="qvc-filters">
                <div class="qvc-filter-group">
                    <label>Estado:</label>
                    <select name="filter_status" onchange="this.form.submit()">
                        <option value="">Todos</option>
                        <option value="unread" <?php selected($filter_status, 'unread'); ?>>Sin leer</option>
                        <option value="read" <?php selected($filter_status, 'read'); ?>>Leído</option>
                        <option value="assigned" <?php selected($filter_status, 'assigned'); ?>>Asignado</option>
                        <option value="processed" <?php selected($filter_status, 'processed'); ?>>Procesado</option>
                    </select>
                </div>
                
                <div class="qvc-filter-group">
                    <label>Categoría:</label>
                    <select name="filter_category" onchange="this.form.submit()">
                        <option value="">Todas</option>
                        <option value="general_inquiries" <?php selected($filter_category, 'general_inquiries'); ?>>Consultas Generales</option>
                        <option value="administrative" <?php selected($filter_category, 'administrative'); ?>>Administrativo</option>
                        <option value="newsletters" <?php selected($filter_category, 'newsletters'); ?>>Newsletters</option>
                    </select>
                </div>
                
                <div class="qvc-filter-group">
                    <label>Prioridad:</label>
                    <select name="filter_priority" onchange="this.form.submit()">
                        <option value="">Todas</option>
                        <option value="high" <?php selected($filter_priority, 'high'); ?>>Alta</option>
                        <option value="medium" <?php selected($filter_priority, 'medium'); ?>>Media</option>
                        <option value="low" <?php selected($filter_priority, 'low'); ?>>Baja</option>
                    </select>
                </div>
                
                <button type="button" onclick="location.href='?page=qvaclick-email-manager&tab=general_inbox'" class="qvc-action-btn secondary">
                    Limpiar Filtros
                </button>
            </div>
            
            <!-- Bulk Actions -->
            <form method="post" class="qvc-bulk-actions">
                <input type="checkbox" id="select-all-inbox" onchange="toggleAllCheckboxes('inbox')">
                <label for="select-all-inbox">Seleccionar todos</label>
                
                <select name="bulk_action">
                    <option value="">Acción en lote...</option>
                    <option value="mark_read">Marcar como leído</option>
                    <option value="assign_to_user">Asignar a usuario</option>
                    <option value="change_priority">Cambiar prioridad</option>
                    <option value="create_ticket">Convertir a ticket</option>
                    <option value="delete">Eliminar</option>
                </select>
                
                <button type="submit" class="qvc-action-btn primary">Aplicar</button>
            </form>
            
            <!-- Email List -->
            <div class="qvc-email-list">
                <?php if (empty($emails)): ?>
                    <div style="padding: 40px; text-align: center; color: #666;">
                        <span class="dashicons dashicons-inbox" style="font-size: 48px; margin-bottom: 10px;"></span>
                        <p>No hay emails en la bandeja general.</p>
                    </div>
                <?php else: ?>
                    <?php foreach ($emails as $email): ?>
                        <div class="qvc-email-item" data-email-id="<?php echo esc_attr($email->id); ?>">
                            <input type="checkbox" class="qvc-email-checkbox inbox-checkbox" value="<?php echo esc_attr($email->id); ?>">
                            
                            <div class="qvc-email-content">
                                <div class="qvc-email-header">
                                    <span class="qvc-email-from"><?php echo esc_html($email->sender_email); ?></span>
                                    <span class="qvc-email-date"><?php echo esc_html(human_time_diff(strtotime($email->created_at))); ?> ago</span>
                                </div>
                                
                                <a href="#" class="qvc-email-subject" onclick="viewEmail(<?php echo esc_attr($email->id); ?>)">
                                    <?php echo esc_html($email->subject); ?>
                                </a>
                                
                                <div class="qvc-email-preview">
                                    <?php echo esc_html(wp_trim_words(strip_tags($email->body), 20)); ?>
                                </div>
                                
                                <div class="qvc-email-meta">
                                    <span class="qvc-email-badge qvc-badge-category">
                                        <?php echo esc_html(ucfirst(str_replace('_', ' ', $email->category))); ?>
                                    </span>
                                    <span class="qvc-email-badge qvc-badge-priority <?php echo esc_attr($email->priority); ?>">
                                        <?php echo esc_html(ucfirst($email->priority)); ?>
                                    </span>
                                    <span class="qvc-email-badge">
                                        Confianza: <?php echo esc_html($email->confidence); ?>%
                                    </span>
                                    <?php if ($email->requires_action): ?>
                                        <span class="qvc-email-badge" style="background: #ffebee; color: #d32f2f;">
                                            Requiere Acción
                                        </span>
                                    <?php endif; ?>
                                </div>
                            </div>
                            
                            <div class="qvc-email-actions">
                                <button type="button" class="qvc-action-btn primary" onclick="processInboxEmail(<?php echo esc_attr($email->id); ?>, 'ticket')">
                                    Crear Ticket
                                </button>
                                <button type="button" class="qvc-action-btn secondary" onclick="processInboxEmail(<?php echo esc_attr($email->id); ?>, 'assign')">
                                    Asignar
                                </button>
                                <button type="button" class="qvc-action-btn secondary" onclick="processInboxEmail(<?php echo esc_attr($email->id); ?>, 'read')">
                                    Marcar Leído
                                </button>
                            </div>
                        </div>
                    <?php endforeach; ?>
                <?php endif; ?>
            </div>
        </div>
        
        <script>
        function toggleAllCheckboxes(type) {
            const checkboxes = document.querySelectorAll('.' + type + '-checkbox');
            const selectAll = document.getElementById('select-all-' + type);
            
            checkboxes.forEach(checkbox => {
                checkbox.checked = selectAll.checked;
            });
        }
        
        function processInboxEmail(emailId, action) {
            const data = {
                action: 'qvc_process_inbox_email',
                email_id: emailId,
                email_action: action,
                nonce: qvc_ajax.nonce
            };
            
            jQuery.post(qvc_ajax.ajax_url, data, function(response) {
                if (response.success) {
                    location.reload();
                } else {
                    alert('Error: ' + response.data);
                }
            });
        }
        
        function viewEmail(emailId) {
            const data = {
                action: 'qvc_view_email',
                email_id: emailId,
                nonce: qvc_ajax.nonce
            };
            
            jQuery.post(qvc_ajax.ajax_url, data, function(response) {
                if (response.success) {
                    showEmailModal(response.data);
                } else {
                    alert('Error: ' + response.data);
                }
            });
        }
        
        function showEmailModal(emailData) {
            // Create modal HTML
            const modalHtml = `
                <div id="qvc-email-modal" class="qvc-modal-overlay">
                    <div class="qvc-modal-content">
                        <div class="qvc-modal-header">
                            <h3>Ver Email</h3>
                            <span class="qvc-modal-close" onclick="closeEmailModal()">&times;</span>
                        </div>
                        <div class="qvc-modal-body">
                            <div class="qvc-email-details">
                                <div class="qvc-detail-row">
                                    <label>De:</label>
                                    <span>${emailData.sender_email}</span>
                                </div>
                                <div class="qvc-detail-row">
                                    <label>Asunto:</label>
                                    <span>${emailData.subject}</span>
                                </div>
                                <div class="qvc-detail-row">
                                    <label>Fecha:</label>
                                    <span>${emailData.created_at}</span>
                                </div>
                                <div class="qvc-detail-row">
                                    <label>Estado:</label>
                                    <select id="email-status" onchange="updateEmailStatus(${emailData.id}, this.value)">
                                        <option value="unread" ${emailData.status === 'unread' ? 'selected' : ''}>Sin leer</option>
                                        <option value="read" ${emailData.status === 'read' ? 'selected' : ''}>Leído</option>
                                        <option value="assigned" ${emailData.status === 'assigned' ? 'selected' : ''}>Asignado</option>
                                        <option value="processed" ${emailData.status === 'processed' ? 'selected' : ''}>Procesado</option>
                                    </select>
                                </div>
                                <div class="qvc-detail-row">
                                    <label>Prioridad:</label>
                                    <select id="email-priority" onchange="updateEmailPriority(${emailData.id}, this.value)">
                                        <option value="low" ${emailData.priority === 'low' ? 'selected' : ''}>Baja</option>
                                        <option value="medium" ${emailData.priority === 'medium' ? 'selected' : ''}>Media</option>
                                        <option value="high" ${emailData.priority === 'high' ? 'selected' : ''}>Alta</option>
                                    </select>
                                </div>
                                <div class="qvc-detail-row">
                                    <label>Categoría:</label>
                                    <span class="qvc-badge">${emailData.category}</span>
                                </div>
                                <div class="qvc-detail-row">
                                    <label>Confianza:</label>
                                    <span>${emailData.confidence}%</span>
                                </div>
                            </div>
                            <div class="qvc-email-body">
                                <h4>Contenido del Email:</h4>
                                <div class="qvc-email-content-display">
                                    ${emailData.body}
                                </div>
                            </div>
                        </div>
                        <div class="qvc-modal-footer">
                            <button type="button" class="qvc-action-btn primary" onclick="convertToTicket(${emailData.id})">
                                Crear Ticket
                            </button>
                            <button type="button" class="qvc-action-btn secondary" onclick="closeEmailModal()">
                                Cerrar
                            </button>
                        </div>
                    </div>
                </div>
            `;
            
            // Add modal to page
            jQuery('body').append(modalHtml);
            
            // Mark as read when opened
            updateEmailStatus(emailData.id, 'read');
        }
        
        function closeEmailModal() {
            jQuery('#qvc-email-modal').remove();
        }
        
        function updateEmailStatus(emailId, status) {
            const data = {
                action: 'qvc_update_email_status',
                email_id: emailId,
                status: status,
                nonce: qvc_ajax.nonce
            };
            
            jQuery.post(qvc_ajax.ajax_url, data, function(response) {
                if (response.success) {
                    console.log('Estado actualizado correctamente');
                } else {
                    alert('Error al actualizar estado: ' + response.data);
                }
            });
        }
        
        function updateEmailPriority(emailId, priority) {
            const data = {
                action: 'qvc_update_email_status',
                email_id: emailId,
                priority: priority,
                nonce: qvc_ajax.nonce
            };
            
            jQuery.post(qvc_ajax.ajax_url, data, function(response) {
                if (response.success) {
                    console.log('Prioridad actualizada correctamente');
                } else {
                    alert('Error al actualizar prioridad: ' + response.data);
                }
            });
        }
        
        function convertToTicket(emailId) {
            if (confirm('¿Estás seguro de que quieres convertir este email en un ticket de soporte?')) {
                processInboxEmail(emailId, 'ticket');
                closeEmailModal();
            }
        }
        </script>
        <?php
    }
    
