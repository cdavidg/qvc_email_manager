<?php
/**
 * Enhanced Admin Email Interface with General Inbox
 * Interfaz de administración mejorada con bandeja general
 * 
 * @package QvaClick_Email_Manager
 */

// Prevent direct access
if (!defined('ABSPATH')) {
    exit;
}

class QvaClick_Enhanced_Admin_Interface {
    
    public function __construct() {
        // DESHABILITADO: Esta interfaz causa duplicación con la interfaz principal
        // Solo se mantiene para compatibilidad de métodos
        // add_action('admin_menu', array($this, 'add_admin_menu'));
        add_action('admin_enqueue_scripts', array($this, 'enqueue_admin_scripts'));
        add_action('wp_ajax_qvc_process_inbox_email', array($this, 'ajax_process_inbox_email'));
        add_action('wp_ajax_qvc_quarantine_action', array($this, 'ajax_quarantine_action'));
        add_action('wp_ajax_qvc_bulk_action', array($this, 'ajax_bulk_action'));
        add_action('wp_ajax_qvc_view_email', array($this, 'ajax_view_email'));
        add_action('wp_ajax_qvc_update_email_status', array($this, 'ajax_update_email_status'));
    }
    
    /**
     * Add admin menu
     */
    public function add_admin_menu() {
        add_menu_page(
            'QvaClick Email Manager',
            'Email Manager',
            'manage_options',
            'qvaclick-email-manager',
            array($this, 'admin_page'),
            'dashicons-email-alt',
            30
        );
    }
    
    /**
     * Enqueue admin scripts and styles
     */
    public function enqueue_admin_scripts($hook) {
        if (strpos($hook, 'qvaclick-email-manager') !== false) {
            wp_enqueue_style('qvc-admin-css', plugin_dir_url(__FILE__) . '../assets/admin-style.css', array(), '1.0.0');
            wp_enqueue_script('qvc-admin-js', plugin_dir_url(__FILE__) . '../assets/admin-script.js', array('jquery'), '1.0.0', true);
            
            wp_localize_script('qvc-admin-js', 'qvc_ajax', array(
                'ajax_url' => admin_url('admin-ajax.php'),
                'nonce' => wp_create_nonce('qvc_admin_nonce')
            ));
        }
    }
    
