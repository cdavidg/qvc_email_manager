    /**
     * AJAX handlers
     */
    public function ajax_process_inbox_email() {
        if (!wp_verify_nonce($_POST['nonce'], 'qvc_admin_nonce')) {
            wp_die('Security check failed');
        }
        
        $email_id = intval($_POST['email_id']);
        $action = sanitize_text_field($_POST['email_action']);
        
        global $wpdb;
        $table = $wpdb->prefix . 'qvc_general_inbox';
        
        switch ($action) {
            case 'read':
                $result = $wpdb->update(
                    $table,
                    array('status' => 'read'),
                    array('id' => $email_id),
                    array('%s'),
                    array('%d')
                );
                break;
                
            case 'ticket':
                // Convert to ticket
                $email = $wpdb->get_row($wpdb->prepare("SELECT * FROM {$table} WHERE id = %d", $email_id));
                if ($email) {
                    $tickets_table = $wpdb->prefix . 'qvc_support_tickets';
                    $wpdb->insert(
                        $tickets_table,
                        array(
                            'user_email' => $email->sender_email,
                            'subject' => $email->subject,
                            'message' => $email->body,
                            'status' => 'open',
                            'priority' => $email->priority,
                            'source' => 'converted_from_inbox',
                            'created_at' => current_time('mysql')
                        )
                    );
                    
                    // Mark as processed
                    $wpdb->update(
                        $table,
                        array('status' => 'processed', 'processed_at' => current_time('mysql')),
                        array('id' => $email_id),
                        array('%s', '%s'),
                        array('%d')
                    );
                }
                $result = true;
                break;
                
            default:
                $result = false;
        }
        
        if ($result !== false) {
            wp_send_json_success('Action completed successfully');
        } else {
            wp_send_json_error('Failed to process action');
        }
    }
    
    /**
     * AJAX handler for viewing email details
     */
    public function ajax_view_email() {
        check_ajax_referer('qvc_admin_nonce', 'nonce');
        
        $email_id = intval($_POST['email_id']);
        if (!$email_id) {
            wp_send_json_error('Invalid email ID');
        }
        
        global $wpdb;
        $table = $wpdb->prefix . 'qvc_general_inbox';
        
        $email = $wpdb->get_row($wpdb->prepare(
            "SELECT * FROM {$table} WHERE id = %d",
            $email_id
        ), ARRAY_A);
        
        if (!$email) {
            wp_send_json_error('Email not found');
        }
        
        // Format the body for display
        $email['body'] = nl2br(esc_html($email['body']));
        
        wp_send_json_success($email);
    }
    
    /**
     * AJAX handler for updating email status and priority
     */
    public function ajax_update_email_status() {
        check_ajax_referer('qvc_admin_nonce', 'nonce');
        
        $email_id = intval($_POST['email_id']);
        if (!$email_id) {
            wp_send_json_error('Invalid email ID');
        }
        
        global $wpdb;
        $table = $wpdb->prefix . 'qvc_general_inbox';
        
        $update_data = array();
        
        // Update status if provided
        if (isset($_POST['status'])) {
            $status = sanitize_text_field($_POST['status']);
            $valid_statuses = array('unread', 'read', 'assigned', 'processed');
            
            if (in_array($status, $valid_statuses)) {
                $update_data['status'] = $status;
                
                // If marking as read, set read timestamp
                if ($status === 'read') {
                    $update_data['read_at'] = current_time('mysql');
                }
                
                // If marking as processed, set processed timestamp
                if ($status === 'processed') {
                    $update_data['processed_at'] = current_time('mysql');
                }
            }
        }
        
        // Update priority if provided
        if (isset($_POST['priority'])) {
            $priority = sanitize_text_field($_POST['priority']);
            $valid_priorities = array('low', 'medium', 'high');
            
            if (in_array($priority, $valid_priorities)) {
                $update_data['priority'] = $priority;
            }
        }
        
        if (empty($update_data)) {
            wp_send_json_error('No valid data to update');
        }
        
        $result = $wpdb->update(
            $table,
            $update_data,
            array('id' => $email_id),
            array(),
            array('%d')
        );
        
        if ($result !== false) {
            wp_send_json_success('Email updated successfully');
        } else {
            wp_send_json_error('Failed to update email');
        }
    }
    
    public function ajax_quarantine_action() {
        if (!wp_verify_nonce($_POST['nonce'], 'qvc_admin_nonce')) {
            wp_die('Security check failed');
        }
        
        $email_id = intval($_POST['email_id']);
        $action = sanitize_text_field($_POST['quarantine_action']);
        
        global $wpdb;
        $table = $wpdb->prefix . 'qvc_email_quarantine';
        
        switch ($action) {
            case 'release':
                $result = $wpdb->update(
                    $table,
                    array('status' => 'released', 'reviewed_by' => get_current_user_id(), 'reviewed_at' => current_time('mysql')),
                    array('id' => $email_id),
                    array('%s', '%d', '%s'),
                    array('%d')
                );
                break;
                
            case 'delete':
                $result = $wpdb->delete($table, array('id' => $email_id), array('%d'));
                break;
                
            default:
                $result = false;
        }
        
        if ($result !== false) {
            wp_send_json_success('Action completed successfully');
        } else {
            wp_send_json_error('Failed to process action');
        }
    }
    
    public function ajax_bulk_action() {
        // Implement bulk actions
        wp_send_json_success('Bulk action completed');
    }
